# xxg-cms Docker Compose 环境变量
# 用法: cp .env.docker.example .env && docker/scripts/bootstrap-docker-env.sh .env && docker compose up -d --build

# MySQL 应用账号（非 root；密码由 bootstrap-docker-env.sh 随机生成）
XXGCMS_DB_HOST=mysql
XXGCMS_DB_PORT=3306
XXGCMS_DB_USER=xxgcms
XXGCMS_DB_PASSWORD=__AUTO__
XXGCMS_MYSQL_ROOT_PASSWORD=__AUTO__
XXGCMS_DB_NAME=xxgcms

# 后台 Django
XXGCMS_SECRET_KEY=__AUTO__
XXGCMS_AUTH_SALT=__AUTO__
XXGCMS_ADMIN_USER=xxgcmsadmin
XXGCMS_ADMIN_PASSWORD=__AUTO__
XXGCMS_CMS_DB_NAME=xxgai
XXGCMS_CMS_SITE_NAME=localhost
XXGCMS_MEDIA_DIR=/data/media
XXGCMS_MEDIA_URL=http://localhost/media/
XXGCMS_ALLOWED_HOSTS=*
XXGCMS_LOG_DIR=/var/log/xxgcms

# 前台 Django
WEBSITE_SECRET_KEY=__AUTO__
WEBSITE_MEDIA_URL=http://localhost/media/
WEBSITE_ALLOWED_HOSTS=*
WEBSITE_LOG_DIR=/var/log/xxgcms
XXGCMS_DEFAULT_THEME=www_xxg_ai

# 是否启用 website 前台路由（1=全栈，/ 代理到 website）
XXGCMS_ENABLE_WEBSITE=1

# AI（可选，留空则 AI 功能不可用）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DASHSCOPE_API_KEY=
BOCHA_API_KEY=
BOCHA_BASE_URL=https://api.bochaai.com
TAVILY_API_KEY=
AI_DEFAULT_TEXT_PROVIDER=deepseek
AI_DEFAULT_IMAGE_PROVIDER=qwen
AI_DEFAULT_SEARCH_PROVIDER=bocha
