# 小西瓜CMS（xxgcms）后端环境变量（敏感项首次 setup/init_env 时自动生成）
XXGCMS_SECRET_KEY=__AUTO__
XXGCMS_AUTH_SALT=__AUTO__
XXGCMS_DB_HOST=127.0.0.1
XXGCMS_DB_PORT=3306
XXGCMS_DB_USER=xxgcms
XXGCMS_DB_PASSWORD=__AUTO__
XXGCMS_DB_NAME=xxgcms
XXGCMS_ADMIN_USER=xxgcmsadmin
XXGCMS_ADMIN_PASSWORD=__AUTO__
# CMS 站点库（init_db 命令使用，对应 sql/cmsdb.sql）
XXGCMS_CMS_DB_NAME=xxgai
XXGCMS_CMS_SITE_NAME=localhost:8088
XXGCMS_MEDIA_DIR=xxgcms_static_files
XXGCMS_MEDIA_URL=http://127.0.0.1:8000/media/
XXGCMS_ALLOWED_HOSTS=*
XXGCMS_LOG_DIR=/var/log/xxgcms

# AI - DeepSeek 文本
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# AI - 通义万相
DASHSCOPE_API_KEY=
# AI - 联网检索（默认 bocha，可改为 tavily）
BOCHA_API_KEY=
BOCHA_BASE_URL=https://api.bochaai.com
TAVILY_API_KEY=
AI_DEFAULT_TEXT_PROVIDER=deepseek
AI_DEFAULT_IMAGE_PROVIDER=qwen
AI_DEFAULT_SEARCH_PROVIDER=bocha
