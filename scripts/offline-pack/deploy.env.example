# 复制为 deploy.env 并填写（deploy.env 已 gitignore，勿提交）
# cp scripts/offline-pack/deploy.env.example scripts/offline-pack/deploy.env

# Ubuntu 构建服务器
REMOTE_USER=abc
REMOTE_HOST=192.168.1.100
REMOTE_DIR=/home/abc/xxg-cms-build
SSH_PORT=22

# SSH 密码（仅本地 deploy.env，已 gitignore；留空则使用 SSH 密钥）
REMOTE_PASSWORD=

# 构建完成后是否自动下载离线包到本地（0=否，手动 scp；1=自动下载）
DOWNLOAD_BUNDLE=0

# 本地保存目录（相对项目根目录）
LOCAL_DOWNLOAD_DIR=.
