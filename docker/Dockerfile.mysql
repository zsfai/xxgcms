FROM mysql:8.0

LABEL org.opencontainers.image.title="xxgcms/mysql"
LABEL org.opencontainers.image.description="xxg-cms private MySQL 8.0 (offline isolated, not shared with other stacks)"

COPY docker/mysql/my.cnf /etc/mysql/conf.d/zz-xxgcms.cnf
COPY docker/mysql/init/ /docker-entrypoint-initdb.d/
RUN chmod +x /docker-entrypoint-initdb.d/*.sh 2>/dev/null || true
