# xxg-cms MySQL 8 — 默认按 2 核 4G 共享部署调优（约 1G 留给 MySQL）
# 若机器内存更大，可将 innodb_buffer_pool_size 调整为物理内存的 25% 左右

[mysqld]
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci
default-authentication-plugin=mysql_native_password

# 连接
max_connections = 80
skip_name_resolve = ON
thread_cache_size = 16
table_open_cache = 512
table_definition_cache = 512

# InnoDB（兼顾小内存与首次启动速度；大内存机器可改为 768M+）
innodb_buffer_pool_size = 512M
innodb_buffer_pool_instances = 2
innodb_log_file_size = 64M
innodb_log_buffer_size = 16M
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT
innodb_io_capacity = 400
innodb_io_capacity_max = 800
innodb_read_io_threads = 4
innodb_write_io_threads = 4
innodb_file_per_table = ON

# 临时表 / 排序（避免单连接占用过多内存）
tmp_table_size = 32M
max_heap_table_size = 32M
sort_buffer_size = 1M
read_buffer_size = 512K
read_rnd_buffer_size = 512K
join_buffer_size = 1M

# 小内存服务器关闭 performance_schema 节省约 100M+
performance_schema = OFF

# 慢查询（>2s 记录，便于后续排查）
slow_query_log = ON
slow_query_log_file = /var/lib/mysql/xxgcms-slow.log
long_query_time = 2

[client]
default-character-set=utf8mb4
