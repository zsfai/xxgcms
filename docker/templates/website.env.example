# 小西瓜CMS（xxgcms）前台环境变量模板
# 由 admin-backend 首次 setup 写入 config 卷，website 容器启动时读取
# 内容同 website/.env.example
WEBSITE_SECRET_KEY=__AUTO__
XXGCMS_DB_HOST=mysql
XXGCMS_DB_PORT=3306
XXGCMS_DB_USER=xxgcms
XXGCMS_DB_PASSWORD=__AUTO__
XXGCMS_DB_NAME=xxgcms
WEBSITE_MEDIA_URL=http://127.0.0.1:8088/media/
XXGCMS_MEDIA_DIR=xxgcms_static_files
WEBSITE_ALLOWED_HOSTS=*
WEBSITE_LOG_DIR=/var/log/xxgcms
XXGCMS_CMS_SITE_NAME=localhost
XXGCMS_DEFAULT_THEME=www_xxg_ai
